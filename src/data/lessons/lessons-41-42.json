    "grammar": [
      {
        "id": "41-1",
        "point": "Ngữ pháp 1",
        "formula": "",
        "jpExplain": "",
        "vnExplain": "さしあげます：Biếu\nあげます：Tặng\nやります：Cho\nCó thể dùng kết hợp với một động từ khác chia ở thể て để diễn tả sự cho nhận hành vi.\nKhuyến khích dùng あげます hơn từ やります vì đây là từ lịch sự hơn.",
        "exampleJp": "",
        "exampleVn": "",
        "exerciseQuestion": "",
        "exerciseAnswer": "",
        "exerciseHint": ""
      },
      {
        "id": "41-2",
        "point": "Ngữ pháp 2",
        "formula": "",
        "jpExplain": "",
        "vnExplain": "Khi cấp trên cho hoặc tặng gì đó cho mình (người thân mình) thì dùng くださいます.\nDùng kết hợp với một động từ chia ở thể て để nói về ai đó làm gì đó cho mình.\nCó thể dùng くださいます cho người thân trong gia đình của người nói.",
        "exampleJp": "",
        "exampleVn": "",
        "exerciseQuestion": "",
        "exerciseAnswer": "",
        "exerciseHint": ""
      },
      {
        "id": "41-3",
        "point": "Hướng dẫn & Giải thích",
        "formula": "Hướng dẫn & Giải thích\nKhi ta nhận từ người cấp trên một cái gì đó thì dùng いただきます\nDùng kết hợp với một động từ khác chia ở thể て để nói về việc mình được giúp đỡ gì đó.\nCó thể dùng いただきます cho người thân trong gia đình của người nói.",
        "jpExplain": "",
        "vnExplain": "",
        "exampleJp": "",
        "exampleVn": "",
        "exerciseQuestion": "",
        "exerciseAnswer": "",
        "exerciseHint": ""
      },
      {
        "id": "41-4",
        "point": "Ngữ pháp 4",
        "formula": "",
        "jpExplain": "",
        "vnExplain": "～Vてくださいませんか : Có thể làm ~ dùm tôi được không?\nYêu cầu người khác làm giúp mình một việc gì đó một cách lịch sự.\n～ Vていただけませんか có mức độ lịch sự cao hơn.",
        "exampleJp": "",
        "exampleVn": "",
        "exerciseQuestion": "",
        "exerciseAnswer": "",
        "exerciseHint": ""
      },
      {
        "id": "41-5",
        "point": "Ngữ pháp 5",
        "formula": "",
        "jpExplain": "",
        "vnExplain": "に：để, để làm.",
        "exampleJp": "",
        "exampleVn": "",
        "exerciseQuestion": "",
        "exerciseAnswer": "",
        "exerciseHint": ""
      }
    ],
