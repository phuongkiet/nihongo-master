    "grammar": [
      {
        "id": "5-1",
        "point": "N (địa điểm) へ 行きます/来ます/帰ります",
        "formula": "N へ 行きます / 来ます / 帰ります",
        "jpExplain": "移動の目的地を示すとき、場所名詞の後に「へ」を使います。発音は「え」です。",
        "vnExplain": "Đi/Đến/Về đâu. Trợ từ 'he' (đọc là 'e') đứng sau địa điểm biểu thị đích đến.",
        "exampleJp": "私は来月日本へ行きます。",
        "exampleVn": "Tháng sau tôi sẽ đi Nhật.",
        "exerciseQuestion": "明日どこ___行きますか。",
        "exerciseAnswer": "へ",
        "exerciseHint": "Trợ từ chỉ hướng đi"
      },
      {
        "id": "5-2",
        "point": "どこ [へ] も 行きません (Phủ định hoàn toàn)",
        "formula": "どこ [へ] も 行きません",
        "jpExplain": "疑問詞＋「も」＋否定形で全否定します。",
        "vnExplain": "Không đi đâu cả. Từ để hỏi + も + phủ định.",
        "exampleJp": "日曜日どこへも行きませんでした。",
        "exampleVn": "Chủ nhật tôi đã không đi đâu cả.",
        "exerciseQuestion": "どこへ___行きません。",
        "exerciseAnswer": "も",
        "exerciseHint": "Trợ từ phủ định tuyệt đối"
      },
      {
        "id": "5-3",
        "point": "N (phương tiện) で V",
        "formula": "N で V",
        "jpExplain": "移動に使用する交通手段や道具を示すとき「で」をつけます。",
        "vnExplain": "Đi bằng phương tiện gì. Trợ từ 'de' biểu thị phương tiện. Đi bộ là 'aruite' (không dùng de).",
        "exampleJp": "タクシーで駅へ行きます。",
        "exampleVn": "Tôi đi taxi ra ga.",
        "exerciseQuestion": "何___京都へ行きますか。",
        "exerciseAnswer": "で",
        "exerciseHint": "Trợ từ chỉ phương tiện"
      },
      {
        "id": "5-4",
        "point": "N (người/động vật) と V",
        "formula": "N と V",
        "jpExplain": "動作を一緒に行う相手を示すとき「と」を使います。",
        "vnExplain": "Làm gì cùng với ai. Trợ từ 'to' đi kèm người đồng hành. Một mình là 'hitoride'.",
        "exampleJp": "友達と病院へ来ました。",
        "exampleVn": "Tôi đến bệnh viện cùng bạn.",
        "exerciseQuestion": "だれ___日本へ来ましたか。",
        "exerciseAnswer": "と",
        "exerciseHint": "Trợ từ chỉ người cùng thực hiện"
      }
    ],
